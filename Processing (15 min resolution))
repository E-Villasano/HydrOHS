# ---------- TOPSIS helper ----------
topsis <- function(Y, weights = NULL, benefit = NULL) {
  Y <- as.matrix(Y)
  stopifnot(nrow(Y) > 0, ncol(Y) > 0)
  m <- ncol(Y)
  
  if (is.null(weights)) weights <- rep(1/m, m)
  weights <- weights / sum(weights)
  
  if (is.null(benefit)) benefit <- rep(FALSE, m)  # FALSE = cost (minimize), TRUE = benefit (maximize)
  stopifnot(length(weights) == m, length(benefit) == m)
  
  # 1) Vector normalization
  denom <- sqrt(colSums(Y^2))
  denom[denom == 0] <- 1
  Z <- sweep(Y, 2, denom, "/")
  
  # 2) Weights
  WZ <- sweep(Z, 2, weights, "*")
  
  # 3) Ideal best/worst by objective type
  ideal_best  <- sapply(seq_len(m), function(j) if (benefit[j]) max(WZ[, j]) else min(WZ[, j]))
  ideal_worst <- sapply(seq_len(m), function(j) if (benefit[j]) min(WZ[, j]) else max(WZ[, j]))
  
  # 4) Distances & closeness
  d_pos <- sqrt(rowSums((sweep(WZ, 2, ideal_best , "-"))^2))
  d_neg <- sqrt(rowSums((sweep(WZ, 2, ideal_worst, "-"))^2))
  Cstar <- d_neg / pmax(d_pos + d_neg, .Machine$double.eps)
  
  list(
    score   = Cstar,
    rank    = rank(-Cstar, ties.method = "min"),
    best_id = which.max(Cstar),
    ideal_best = ideal_best,
    ideal_worst = ideal_worst
  )
}

