library(ggplot2)
library(plotly)
library(dplyr)
library(tidyr)

# ---- A) Prepare data ----
dfl_filt_clean <- dfl_filt %>%
  mutate(across(c(SC, SCb, SCy), as.numeric)) %>%  # ensure numeric
  mutate(time = index(dfl_filt))                   # numeric index for plotting

# Reshape to long format for legend support
dfl_long <- dfl_filt_clean %>%
  pivot_longer(cols = c(SC, SCb, SCy),
               names_to = "Type",
               values_to = "Value")

# Extract datetime vector
dt_vals <- dfl_filt$datetime  # POSIXct

# ---- B) Determine exact year-start tick marks ----
tick_years <- c(2009, 2014, 2019, 2024)  # adjust years as needed
# Select datetimes exactly at midnight of Jan 1 for each tick year
tick_dates <- dt_vals[format(dt_vals, "%Y-%m-%d %H:%M:%S") %in%
                        paste0(tick_years, "-01-01 00:00:00")]
# Get row indices for those datetimes
brks <- which(dt_vals %in% tick_dates)

# ---- C) Build the plot ----
p53 <- ggplot(dfl_long, aes(x = time, y = Value, color = Type)) +
  geom_line(alpha = 1, linewidth = 0.5) +  # thinner lines for high-res data
  scale_color_manual(values = c("SC" = "grey", "SCb" = "blue", "SCy" = "red")) +
  labs(
    x = "Time (15 min interval)",
    y = "SC (µS/cm)",
    title = "Cholollo Campground 15 - Time vs SC",
    color = "Line Type"
  ) +
  scale_x_continuous(
    breaks = brks,
    labels = format(dt_vals[brks], "%Y")  # show only the year
  ) +
  theme_classic() +
  theme(
    axis.title = element_text(size = 18, face = "bold"),
    axis.text  = element_text(size = 14, face = "bold"),
    plot.title = element_text(size = 20, face = "bold"),
    legend.title = element_text(size = 16, face = "bold"),
    legend.text  = element_text(size = 14, face = "bold")
  )

# ---- D) Convert to interactive ----
p53_interactive <- ggplotly(p53)
p53_interactive

# ---- E) Save static PNG ----
ggsave("p53_highres_plot.png", plot = p53, width = 9, height = 4, dpi = 300)
