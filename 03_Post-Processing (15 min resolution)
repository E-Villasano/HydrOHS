b <- rep(NaN, length(dfl$strflow))


b[1] <- dfl$strflow[1]*x2*0.9  

for (i in 2:length(dfl$strflow)){
  b[i] <- (((1-x2)*x1*b[i-1]) + ((1-x1)*x2*dfl$strflow[i]))/(1-x1*x2)
  
    if (is.na(b[i]))    b[i] <- dfl$strflow[i]  # set logical index to prevent crash at BFImax = 1
  if (b[i]<0|is.na(b[i]))    b[i] <- dfl$strflow[i]*x2*0.9 
  if (b[i]>dfl$strflow[i]) b[i] <- dfl$strflow[i]
}

dfl$b = b

dfl$y = dfl$strflow - b

dfl$bfi <- ifelse(dfl$strflow == 0, -1, dfl$b/dfl$strflow)  

dfl$bfi <- round(dfl$bfi, digits = 6)   

################################################################################
